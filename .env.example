# ── AgentSDLC Environment Variables ──

# ── LLM Configuration
LLM_PROVIDER=anthropic # anthropic | openai | bedrock | copilot
ANTHROPIC_API_TOKEN=
OPENAI_API_KEY=
AWS_REGION=us-east-1
GITHUB_COPILOT_TOKEN=

# ── Project Context
HOST_PROJECT_PATH=C:\path\to\your\application
PROJECT_GIT_URL=https://github.com/user/repo.git

# ── GitHub Integration (For PR Gates)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main

# ── Jira Integration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ── Figma Integration (For Design Agent)
FIGMA_ACCESS_TOKEN=
FIGMA_TEAM_ID=
FIGMA_PROJECT_ID=

# ── Gate Configuration (Approval Strategy)
GATE_STRATEGY=web_ui # web_ui | github_review | jira_transition
JIRA_APPROVED_STATUS=Ready for Dev

# ── Notifications (Slack)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_PO=#product
SLACK_CHANNEL_DESIGN=#design
SLACK_CHANNEL_QA=#qa
SLACK_CHANNEL_CICD=#deployments
SLACK_CHANNEL_ARCH=#engineering

# ── QA / Testing (Playwright)
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_VIDEOS_DIR=./qa-videos
